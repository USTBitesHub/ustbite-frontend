# Git
.git
.gitignore
.github

# Node modules (rebuilt in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (copied from builder stage only)
dist/
build/

# Environment files (secrets must NOT go in the image)
.env
.env.*
.env.local
.env.development
.env.production

# IDE & OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Docker itself
Dockerfile
.dockerignore

# Docs
*.md
README*

# Test files
*.test.ts
*.spec.ts
*.test.tsx
*.spec.tsx
coverage/
__tests__/

# TypeScript cache
*.tsbuildinfo
